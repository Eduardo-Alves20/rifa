# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL - Neon.tech recomendado)
DATABASE_URL="postgresql://user:password@host:5432/sorteiofacil?sslmode=require"

# JWT (gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="troque-isso-em-producao-use-64-bytes-aleatorios"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# HMAC para QR Codes (chave separada do JWT)
HMAC_SECRET="troque-isso-tambem-chave-separada-do-jwt"

# CORS - URL do frontend
FRONTEND_URL="http://localhost:3000"

# Admin inicial (usado no seed)
ADMIN_EMAIL="admin@sorteiofacil.com"
ADMIN_PASSWORD="trocar123"
ADMIN_NOME="Administrador"
ADMIN_CPF="00000000000"
ADMIN_USUARIO="admin"
