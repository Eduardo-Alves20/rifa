# Copie para .env.prod e preencha. NUNCA comite o .env.prod real.
# Gere segredos com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# Banco (Postgres local no Docker)
POSTGRES_PASSWORD=troque-isto

# Segredos da API (>= 32 caracteres)
JWT_SECRET=troque-por-64-hex-aleatorios
HMAC_SECRET=troque-por-64-hex-aleatorios

# URL pública do frontend (CORS)
FRONTEND_URL=https://pitstopclub.com.br

# Admin inicial (criado no primeiro boot)
ADMIN_EMAIL=admin@pitstopclub.com.br
ADMIN_PASSWORD=troque-isto
ADMIN_NOME=Administrador
ADMIN_CPF=00000000000
ADMIN_USUARIO=admin
